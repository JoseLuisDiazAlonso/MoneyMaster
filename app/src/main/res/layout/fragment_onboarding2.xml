<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.onboarding.fragment_onboarding2">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="?attr/colorSurface"
            android:paddingTop="48dp"
            android:paddingBottom="48dp"
            android:paddingLeft="24dp"
            android:paddingRight="24dp">

            <ImageView
                android:id="@+id/imageOnboarding"
                android:layout_width="200dp"
                android:layout_height="160dp"
                android:src="@drawable/finance"
                android:contentDescription="@string/onboarding2_title"
                android:background="@drawable/bg_rounded_shadow"
                android:elevation="8dp"
                android:padding="20dp"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tvTitle2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/onboarding2_title"
                android:textColor="?attr/colorOnSurface"
                android:gravity="center"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDescription2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="@string/onboarding2_description"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>