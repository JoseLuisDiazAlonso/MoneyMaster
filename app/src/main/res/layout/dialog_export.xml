<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: dialog_export.xml
    Ubicación: res/layout/dialog_export.xml
    BottomSheet para seleccionar formato (CSV/PDF) y período de exportación.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?attr/colorSurface">

    <!-- ── Handle del BottomSheet ────────────────────────────────────────── -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <!-- ── Título ─────────────────────────────────────────────────────────── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Exportar datos"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selecciona el formato y el período"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="20dp" />

    <!-- ── Sección: Formato ───────────────────────────────────────────────── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Formato"
        android:textAppearance="?attr/textAppearanceLabelLarge"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_formato"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <!-- CSV -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_description"
                    android:tint="?attr/colorPrimary"
                    android:contentDescription="@null"
                    android:layout_marginBottom="4dp" />

                <RadioButton
                    android:id="@+id/rb_csv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CSV"
                    android:checked="true"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:gravity="center"
                    android:button="@null"
                    android:drawableStart="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Excel, Sheets"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- PDF -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_picture_as_pdf"
                    android:tint="#C62828"
                    android:contentDescription="@null"
                    android:layout_marginBottom="4dp" />

                <RadioButton
                    android:id="@+id/rb_pdf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PDF"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:gravity="center"
                    android:button="@null"
                    android:drawableStart="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informe completo"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </RadioGroup>

    <!-- ── Sección: Período ───────────────────────────────────────────────── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Período"
        android:textAppearance="?attr/textAppearanceLabelLarge"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_periodo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/rb_mes_actual"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Mes actual"
            android:checked="true"
            android:paddingStart="8dp"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <RadioButton
            android:id="@+id/rb_anio_actual"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Año actual"
            android:paddingStart="8dp"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <RadioButton
            android:id="@+id/rb_todo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Todo el historial"
            android:paddingStart="8dp"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

    </RadioGroup>

    <!-- ── Progreso (oculto hasta que se exporta) ─────────────────────────── -->
    <LinearLayout
        android:id="@+id/layout_progreso"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progress_export_dialog"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tv_progreso_texto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Generando archivo..."
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

    <!-- ── Botones de acción ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancelar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Cancelar"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_exportar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Exportar"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

</LinearLayout>