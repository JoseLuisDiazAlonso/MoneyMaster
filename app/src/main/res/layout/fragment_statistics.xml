<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_statistics.xml
     Contenedor principal de la pantalla de Estadísticas.
     Estructura: TabLayout (fijo en la parte superior) + ViewPager2 (ocupa el resto). -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Pestañas: Mes actual · Año · Personalizado -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutStatistics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorColor="?attr/colorPrimary"
        app:tabSelectedTextColor="?attr/colorPrimary"
        app:tabTextColor="?attr/colorOnSurfaceVariant"
        app:tabRippleColor="?attr/colorPrimaryContainer"
        style="@style/Widget.Material3.TabLayout" />

    <!-- Contenido de cada pestaña -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerStatistics"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>