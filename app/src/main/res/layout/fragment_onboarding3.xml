<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.onboarding.fragment_onboarding3">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="?attr/colorSurface"
            android:paddingTop="48dp"
            android:paddingBottom="48dp"
            android:paddingLeft="24dp"
            android:paddingRight="24dp">

            <!--Imagen ilustrativa-->
            <ImageView
                android:id="@+id/imageOnboarding3"
                android:layout_width="200dp"
                android:layout_height="160dp"
                android:src="@drawable/onboarding3_picture"
                android:background="@drawable/bg_rounded_shadow"
                android:elevation="8dp"
                android:padding="20dp"
                android:scaleType="fitCenter" />

            <!--Título-->
            <TextView
                android:id="@+id/tvTitle3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Privacidad garantizada"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:gravity="center" />

            <!--Texto Descriptivo-->
            <TextView
                android:id="@+id/tvDescription3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Todos tus datos se almacenan únicamente en tu dispositivo, sin conexión a internet"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="16sp" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>