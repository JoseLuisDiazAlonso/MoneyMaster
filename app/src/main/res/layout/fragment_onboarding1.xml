<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.onboarding.fragment_onboarding1">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="?attr/colorSurface"
            android:paddingTop="48dp"
            android:paddingBottom="48dp"
            android:paddingLeft="24dp"
            android:paddingRight="24dp">

            <!--Imagen Ilustrativa-->
            <ImageView
                android:id="@+id/iconContainer"
                android:layout_width="200dp"
                android:layout_height="160dp"
                android:src="@drawable/iv_illustration"
                android:background="@drawable/bg_rounded_shadow"
                android:elevation="8dp"
                android:padding="20dp"
                android:scaleType="fitCenter" />

            <!--Texto de Título-->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="@string/controla_tus_finanzas"
                android:textColor="?attr/colorOnSurface"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!--Texto Descriptivo-->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="@string/lleva_un_registro_completo_de_tus_gastos_e_ingresos_en_un_solo_lugar"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="16sp" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>