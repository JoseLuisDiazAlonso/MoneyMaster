<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Icono de advertencia -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_warning"
        android:tint="@color/expense_red"
        android:contentDescription="@null" />

    <!-- Texto de advertencia -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Esta acción eliminará permanentemente:"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?attr/colorOnSurface" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:text="• Todos los gastos e ingresos personales\n• Todos los grupos y gastos grupales\n• Todas las fotos de recibos\n• Tu cuenta de usuario"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="@color/expense_red" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Las categorías predefinidas del sistema se restaurarán automáticamente."
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <!-- Divisor -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:background="?attr/colorOutlineVariant" />

    <!-- Checkbox de confirmación -->
    <CheckBox
        android:id="@+id/cbConfirmarEliminar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Entiendo que esto es irreversible"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?attr/colorOnSurface"
        android:buttonTint="@color/expense_red" />

</LinearLayout>