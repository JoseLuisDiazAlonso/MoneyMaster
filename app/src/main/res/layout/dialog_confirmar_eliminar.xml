<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Icono de advertencia -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_warning"
        android:tint="@color/expense_red"
        android:contentDescription="@null" />

    <!-- Texto de advertencia -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/esta_acci_n_eliminar_permanentemente"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?attr/colorOnSurface" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:text="@string/todos_los_gastos_e_ingresos_personales_n_todos_los_grupos_y_gastos_grupales_n_todas_las_fotos_de_recibos_n_tu_cuenta_de_usuario"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="@color/expense_red" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/las_categor_as_predefinidas_del_sistema_se_restaurar_n_autom_ticamente"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <!-- Divisor -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:background="?attr/colorOutlineVariant" />

    <!-- Checkbox de confirmación -->
    <CheckBox
        android:id="@+id/cbConfirmarEliminar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/entiendo_que_esto_es_irreversible"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?attr/colorOnSurface"
        android:buttonTint="@color/expense_red" />

</LinearLayout>