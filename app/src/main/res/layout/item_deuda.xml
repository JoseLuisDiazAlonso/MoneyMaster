<?xml version="1.0" encoding="utf-8"?>
<!-- item_deuda.xml -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Avatar deudor -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp">

            <View
                android:id="@+id/viewDeudorColor"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle"
                tools:background="#9C27B0" />

            <TextView
                android:id="@+id/textViewDeudorInicial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                tools:text="C" />

        </FrameLayout>

        <!-- Texto de la deuda -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textViewDeuda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="?attr/colorOnSurface"
                tools:text="Carlos debe 30,00 EUR a Ana" />

            <!-- Etiqueta "Pagado" cuando está marcada -->
            <TextView
                android:id="@+id/textViewEstadoDeuda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Pagado"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- Botón marcar como pagado -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonMarcarPagado"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Pagado"
            android:textSize="12sp"
            app:icon="@drawable/ic_check"
            app:iconSize="16dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>