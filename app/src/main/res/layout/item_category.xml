<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Fondo circular del icono -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <!-- Fondo coloreado (tint dinámico via código) -->
            <View
                android:id="@+id/viewIconBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_circle" />

            <!-- Icono de la categoría (tint dinámico via código) -->
            <ImageView
                android:id="@+id/imageCategoryIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="Icono de categoría" />

        </FrameLayout>

        <!-- Nombre de la categoría -->
        <TextView
            android:id="@+id/textCategoryName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="?attr/colorOnSurface" />

        <!-- Chip "Predefinida" (solo visible en categorías predefinidas) -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipPredefined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Predefinida"
            android:textSize="10sp"
            app:chipMinHeight="24dp"
            android:clickable="false"
            android:focusable="false"
            app:chipBackgroundColor="?attr/colorSecondaryContainer"
            app:chipStrokeWidth="0dp"
            android:visibility="gone" />

        <!-- Botón eliminar (solo visible en categorías custom) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDeleteCategory"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="Eliminar categoría"
            app:icon="@drawable/ic_delete"
            app:iconTint="?attr/colorError"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>