<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Permiso de internet para enviar emails -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <uses-permission android:name="android.permission.INTERNET" /> <!-- Permiso de Cámara -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:name=".MoneyMasterApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MoneyMaster"
        tools:targetApi="31">
        <activity
            android:name=".ui.BaseActivity"
            android:exported="false" />
        <activity
            android:name=".AcercaDeActivity"
            android:exported="false" />
        <activity
            android:name=".ImageViewerActivity"
            android:exported="false" />
        <activity
            android:name=".ui.groups.GroupDetailActivity"
            android:exported="false" />
        <activity
            android:name=".CreateGroupActivity"
            android:exported="false" />
        <activity
            android:name=".AddIncomeActivity"
            android:exported="false"
            android:theme="@style/Theme.MoneyMaster" />
        <activity
            android:name=".AddExpenseActivity"
            android:exported="false"
            android:theme="@style/Theme.MoneyMaster" /> <!-- Registro de usuario -->
        <activity
            android:name=".ActivityRegister"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" /> <!-- Onboarding -->
        <activity
            android:name=".activity_onboarding"
            android:exported="false" /> <!-- Splash Screen — punto de entrada de la app -->
        <activity
            android:name=".ui.onboarding.Splash"
            android:exported="true"
            android:theme="@style/Theme.MoneyMaster">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- Onboarding slides -->
        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false" /> <!-- Login -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" /> <!-- Recuperar Contraseña ← NUEVO -->
        <activity
            android:name=".ui.auth.RecuperarContrasenaActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" /> <!-- Pantalla principal -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.MoneyMaster"
            android:windowSoftInputMode="adjustResize" /> <!-- Activity Add Expense -->
        <activity
            android:name=".ui.expense.AddExpenseActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" /> <!-- FileProvider (añadir dentro de <application>) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".ui.income.AddIncomeActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.groups.CreateGroupActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.viewer.ImageViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.MoneyMaster"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.expenses.AddExpenseActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
    </application>

</manifest>